{
  "version": 2,
  "name": "entropy-of-longing",
  "public": true,
  "github": {
    "enabled": true,
    "silent": true
  },
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
